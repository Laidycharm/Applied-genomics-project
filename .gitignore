*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site
docs/

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# Genomic data files ( too large for Github)
*.fastq
*.fastq.gz
*.sra
*.bam
*.bai

# # Reference files (too large)
reference/genome/*.fa
reference/genome/*.fa.gz
reference/annotation/*.gtf.gz
reference/index/*.ht2

